    {
        "id": "8ee3b3579e8a41e2",
        "type": "function",
        "z": "74fbcf30aa60669d",
        "name": "Traitement statut",
        "func": "var status = msg.payload;\nvar now = new Date();\nvar ts = now.toLocaleString('fr-FR');\n\nif (status === 'LOCK') status = 'LOCKED';\nif (status === 'UNLOCK') status = 'UNLOCKED';\n\n// msg1 : statut texte\nvar msg1 = { payload: status };\n\n// msg2 : alerte MQTT JSON\nvar alertPayload = JSON.stringify({\n  timestamp: now.toISOString(),\n  event: status === 'LOCKED' ? 'DOOR_LOCKED' : 'DOOR_UNLOCKED',\n  status: status,\n  message: status === 'LOCKED' ? 'Porte verrouillée' : 'ALERTE : Porte déverrouillée'\n});\nvar msg2 = { payload: alertPayload, topic: 'door/alert' };\n\n// msg3 : historique cumulatif\nvar logs = flow.get('alertLogs') || [];\nvar icon = status === 'LOCKED' ? '🔒' : '🔓';\nvar newEntry = '[' + ts + '] ' + icon + ' ' + status;\nlogs.unshift(newEntry);\nif (logs.length > 50) logs.pop();\nflow.set('alertLogs', logs);\nvar msg3 = { payload: logs };\n\n// msg4 : couleur LED\nvar msg4 = { payload: status === 'LOCKED' ? 'red' : 'green' };\n\nreturn [msg1, msg2, msg3, msg4];",
        "outputs": 4,
        "x": 340,
        "y": 160,
        "wires": [
            [
                "8dc8b0d38109a41c"
            ],
            [
                "96cc5c51afaf4b4c"
            ],
            [
                "7108a3ec8a4dabc8"
            ],
            [
                "e170043782b3c1fd"
            ]
        ]
    },
