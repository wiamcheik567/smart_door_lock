        "order": 1,
        "width": "12",
        "height": "8",
        "format": "<div style='background:#1e1e1e;border-radius:8px;padding:10px;height:220px;overflow-y:auto;font-family:monospace;font-size:13px;color:#e0e0e0'>\n  <div style='color:#90caf9;font-weight:bold;margin-bottom:8px;font-size:14px'>📋 Historique des alertes</div>\n  <div ng-if='!msg.payload || msg.payload.length === 0' style='color:#666;font-style:italic'>Aucune alerte enregistrée</div>\n  <div ng-repeat='log in msg.payload track by $index'\n       ng-style=\"{'color': log.indexOf('UNLOCKED') !== -1 ? '#66bb6a' : '#ef5350'}\"\n       style='padding:5px 4px;border-bottom:1px solid #333;line-height:1.5'>\n    {{log}}\n  </div>\n</div>",
